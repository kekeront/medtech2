# Copy to .env (or just export these). Defaults match the local Postgres setup below.
DATABASE_URL=postgresql+psycopg2://medarchive:medarchive@localhost:5432/medarchive

# Normalization thresholds (cosine/fuzzy similarity 0..1)
MEDARCHIVE_MATCH_AUTO=0.85
MEDARCHIVE_MATCH_SUGGEST=0.55

# Validation
MEDARCHIVE_PRICE_ANOMALY_PCT=0.50

# FX -> KZT (used only when a price is not in KZT)
FX_USD_KZT=525
FX_RUB_KZT=5.7

# Where originals + extracted data live
MEDARCHIVE_DATA_DIR=./data
